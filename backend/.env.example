# ============================================================
# AI 文档知识库（MVP）后端环境变量模板
# ============================================================
# 用法:
#   cp .env.example .env
#   nano .env  # 填写真实配置
#
# 注意:
#   - .env 已被 .gitignore 排除，不会提交到 Git
#   - 标记 [必填] 的项必须填写，否则后端无法启动
#   - 标记 [可选] 的项有默认值，可保留默认
# ============================================================

# ===== 应用配置 =====
# [可选] 后端监听地址，localhost 部署保持 127.0.0.1
APP_HOST=127.0.0.1
# [可选] 后端监听端口
APP_PORT=8000
# [可选] 调试模式：true 暴露 /docs API 文档，false 隐藏（SEC-003）
# 演示与生产环境必须为 false
DEBUG=false

# ===== MariaDB =====
# [必填] MariaDB 异步连接串
# 格式: mysql+asyncmy://用户名:密码@主机:端口/数据库名
# 示例: mysql+asyncmy://root:your_password@127.0.0.1:3306/ai_knowledge_base
# 注意：密码中如含特殊字符需 URL 编码（@ → %40 等）
DATABASE_URL=mysql+asyncmy://root:password@127.0.0.1:3306/ai_knowledge_base

# ===== OpenAI =====
# [必填] OpenAI API Key，从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# [可选] OpenAI API 基址，可配置第三方兼容代理
OPENAI_BASE_URL=https://api.openai.com/v1
# [可选] LLM 模型名（DEC-007）
LLM_MODEL=gpt-4o-mini
# [可选] Embedding 模型名
EMBEDDING_MODEL=text-embedding-3-small

# ===== Embedding Provider =====
# [可选] Embedding Provider: openai（在线，1536 维）或 bge（本地，1024 维）
# 切换后必须重启后端服务（M-002 已知问题，V1.1 修复热切换）
# 切换后需重建向量索引（删除 backend/data/chroma/ 后重新上传文档）
EMBEDDING_PROVIDER=openai

# ===== 本地模型（bge-m3，可选）=====
# [可选] 本地模型缓存目录，仅在 EMBEDDING_PROVIDER=bge 时使用
# 首次加载需下载几百 MB~1GB 模型文件
MODEL_CACHE_DIR=./data/models

# ===== Chroma 向量库 =====
# [可选] Chroma 嵌入式持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# ===== RAG 参数 =====
# [可选] 文本切片大小（字符数，DEC-016）
CHUNK_SIZE=500
# [可选] 切片重叠（字符数）
CHUNK_OVERLAP=50
# [可选] 检索返回的最相似结果数量
TOP_K=5
# [可选] 相似度阈值，低于此值的片段被过滤
SIMILARITY_THRESHOLD=0.3
# [可选] 多轮对话保留的历史轮数（DEC-011）
MAX_HISTORY_ROUNDS=4

# ===== 文件上传 =====
# [可选] 上传文件存储目录
UPLOAD_DIR=./data/uploads
# [可选] 单文件大小上限（MB）
MAX_FILE_SIZE_MB=20
# [可选] 文档总数上限
MAX_DOCUMENTS=100

# ===== LLM 超时与重试 =====
# [可选] LLM 非流式调用超时（秒）
LLM_TIMEOUT=30
# [可选] LLM 流式调用超时（秒）
LLM_STREAM_TIMEOUT=60
# [可选] LLM 最大重试次数（仅对超时与连接错误重试，指数退避 1s/2s/4s）
LLM_MAX_RETRIES=3
